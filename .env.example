# Local defaults for the POC. Copy to .env locally or set these in your staging provider.
# Never commit real values.

# Rails/customer test data
SEED_CUSTOMER_PHONE=+15551234567

# WhatsApp webhook verification. Use the same value in Meta's webhook setup UI.
WHATSAPP_WEBHOOK_VERIFY_TOKEN=replace-me

# During local/staging dry-runs, replies are logged instead of sent.
# Set to cloud_api only after configuring WHATSAPP_ACCESS_TOKEN and WHATSAPP_PHONE_NUMBER_ID.
WHATSAPP_SEND_MODE=log
WHATSAPP_GRAPH_VERSION=v23.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# Optional: comma-separated allowlist so only your own WhatsApp number can use staging.
WHATSAPP_ALLOWED_SENDERS=+15551234567

# deterministic is fast and testable. Use pi to invoke the Pi CLI runtime.
PI_AGENT_MODE=deterministic
PI_COMMAND=pi
PI_AGENT_TIMEOUT_SECONDS=30
